<?xml version="1.0" encoding="UTF-8" ?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
    <persistence-unit name="BankPU" transaction-type="JTA">
        <jta-data-source>jdbc_national_bank</jta-data-source>
        <class>lk.jiat.bank.core.model.User</class>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
            <property name="jakarta.persistence.sharedCache.mode" value="NONE"/>
            <property name="eclipselink.cache.shared.default" value="false"/>
        </properties>
    </persistence-unit>
</persistence>